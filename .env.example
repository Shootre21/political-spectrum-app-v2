# Political Spectrum App - Environment Configuration
# 
# IMPORTANT: The app works FULLY without any configuration!
# - Algorithm-based analysis works 100% locally (no API keys needed)
# - RSS feeds work without any setup (no database needed)
# - All core features work out of the box

# ==============================================
# DATABASE (OPTIONAL)
# ==============================================
# If you want to persist articles between sessions, set up SQLite:
# DATABASE_URL="file:./db/custom.db"
#
# Then run:
# npx prisma db push
# npx prisma generate

# ==============================================
# AI API KEYS (OPTIONAL - For AI-powered analysis)
# ==============================================
# Only needed if you want AI-powered deep analysis
# The app works perfectly fine with algorithm-based analysis

# OpenAI / ChatGPT
# Get your key: https://platform.openai.com/api-keys
# OPENAI_API_KEY="sk-proj-your-key-here"

# Anthropic / Claude
# Get your key: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY="sk-ant-your-key-here"

# Google Gemini
# Get your key: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY="AIza-your-key-here"

# xAI / Grok
# Get your key: https://console.x.ai/
# GROK_API_KEY="xai-your-key-here"

# Moonshot / Kimi (Chinese AI)
# Get your key: https://platform.moonshot.cn/console/api-keys
# KIMI_API_KEY="sk-your-key-here"

# ==============================================
# SITE CONFIGURATION
# ==============================================
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
